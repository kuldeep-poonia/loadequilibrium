            { "color": "green", "value": null },
            { "color": "yellow", "value": 0.4 },
            { "color": "red", "value": 0.7 }
          ]}
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 33 },
      "id": 41,
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "list", "placement": "bottom" } },
      "title": "Hazard Score [0-1] by Service",
