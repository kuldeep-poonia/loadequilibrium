      "datasource": { "type": "prometheus", "uid": "prometheus-le" },
      "fieldConfig": {
        "defaults": { "unit": "percentunit", "min": 0, "max": 1,
          "custom": { "lineWidth": 2, "fillOpacity": 10 },
