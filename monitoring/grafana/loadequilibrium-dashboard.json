      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 6 },
      "id": 10,
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "list", "placement": "bottom" } },
      "title": "Arrival Rate (rps) by Service",
      "type": "timeseries",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus-le" },
          "expr": "loadequilibrium_request_rate",
          "legendFormat": "{{service}}"
        }
      ]
    },

    {
      "datasource": { "type": "prometheus", "uid": "prometheus-le" },
      "fieldConfig": {
        "defaults": { "unit": "none", "custom": { "lineWidth": 2, "fillOpacity": 10 },
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null },
            { "color": "yellow", "value": 100 },
            { "color": "red", "value": 200 }
          ]}
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 6 },
      "id": 11,
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "list", "placement": "bottom" } },
      "title": "Queue Depth by Service",
      "type": "timeseries",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus-le" },
          "expr": "loadequilibrium_queue_depth",
          "legendFormat": "{{service}}"
        }
      ]
    },

    {
